# HubSpot Private App token
# Create at: HubSpot > Settings > Integrations > Private Apps
# Required scopes: crm.objects.deals.read, crm.objects.contacts.read
HUBSPOT_API_KEY=pat-xx1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Brevo API key
# Find at: Brevo > Account > SMTP & API > API Keys
BREVO_API_KEY=xkeysib-your-api-key-here

# Brevo list IDs
# Find at: Brevo > Contacts > Lists > click list > number in URL
BREVO_LIST_CZ=1
BREVO_LIST_EN=2
